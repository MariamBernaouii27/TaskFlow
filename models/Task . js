const mongoose = require('mongoose');

const taskSchema = new mongoose.Schema({
    titre: {
        type: String,
        required: true,
        trim: true
    },
    description: {
        type: String,
        trim: true
    },
    statut: {
        type: String,
        enum: ['À faire', 'En cours', 'Terminé'],
        default: 'À faire'
    },
    dateEcheance: {
        type: Date
    },
    // تاش 4: ربط المهمة بالمستخدم (Assignation)
    assigneA: {
        type: mongoose.Schema.Types.ObjectId,
        ref: 'User',
        required: false
    }
}, {
    timestamps: true
});

module.exports = mongoose.model('Task', taskSchema);s
